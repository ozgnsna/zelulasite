# Site kökü (ödeme dönüş URL’leri; production’da https ile tam alan adı)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Opsiyonel: ana sayfa kahraman videosu (sessiz .mp4, public veya CDN URL)
NEXT_PUBLIC_HERO_VIDEO_URL=""
# Opsiyonel: ürün sayfası galeri üzerinde döngü video
NEXT_PUBLIC_PDP_VIDEO_URL=""

NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
# Hediye kartı kapak görseli (opsiyonel tam URL; yoksa …/product-images/zelula-gift-card.svg)
# NEXT_PUBLIC_GIFT_CARD_IMAGE_URL="https://YOUR_PROJECT.supabase.co/storage/v1/object/public/product-images/zelula-gift-card.svg"
# Supabase Dashboard → Authentication → URL Configuration → Redirect URLs:
#   http://localhost:3000/auth/callback
#   https://YOUR_DOMAIN/auth/callback
# Site URL / e-posta şablonları: NEXT_PUBLIC_SITE_URL ile aynı kök (şifre sıfırlama)
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# --- QNB Finansbank vPOS (kart ödemesi) ---
# Panel “API Entegrasyon Kullanıcı Bilgileri” → env eşlemesi:
#   Üye İşyeri Numarası (MerchantID) → QNB_MERCHANT_ID  (baştaki sıfırları silmeyin)
#   Kullanıcı Adı (User Code)       → QNB_USER_CODE
#   API kullanıcı şifresi           → QNB_USER_PASS     (sohbete yazmayın; yalnızca Vercel)
#   Kurum kodu (MbrId)              → QNB_MBR_ID        (bankanın söylediği; çoğu entegrasyonda 5)
#   Terminal Numarası               → şu an POST’ta kullanılmıyor (Gateway/3DPay Help örneği)
# Ayrı belge: “Üye İşyeri 3D Şifresi” / StoreKey → QNB_MERCHANT_PASS (init Hash sonuna eklenir; QNB_USER_PASS DEĞİL)
# PurchAmount hash + POST: her zaman nokta + 2 ondalık (örn. 375.00) — QNB_PURCH_AMOUNT_DECIMAL kullanılmaz
# Test: QNB_TEST_MODE=1 → vpostest.qnb.com.tr | Canlı: QNB_TEST_MODE=0
QNB_MBR_ID="5"
QNB_MERCHANT_ID="093600000047456"
QNB_USER_CODE="zelulaapi"
QNB_USER_PASS=""
QNB_MERCHANT_PASS=""
# Help 3DPay örneği POST’ta MerchantPass kullanır. Banka “göndermeyin” derse: true
# QNB_OMIT_MERCHANT_PASS_IN_POST="true"
# 3DPay = kart üye işyeri sayfasında, POST → …/Gateway/Default.aspx. 3DHost = yalnızca banka sayfası, POST → …/3DHost.aspx.
QNB_SECURE_TYPE="3DPay"
# Canlıda yanlışlıkla 3DHost kaldıysa tüm istekleri 3DPay’e zorlar (acil geçiş).
# QNB_FORCE_3DPAY="true"
# Sunucu + istemci konsolunda ödeme yönlendirme teşhisi (geçici). Prod: yalnızca gerektiğinde açın.
# QNB_PAY_FLOW_DEBUG="1"
# Checkout yanıtı / redirectUrl (sunucu log). İstemci için ayrıca NEXT_PUBLIC_CHECKOUT_DEBUG kullanın.
# CHECKOUT_HANDOFF_DEBUG="1"
# NEXT_PUBLIC_CHECKOUT_DEBUG="1"
# Canlı: QNB_TEST_MODE=0
QNB_TEST_MODE="1"
# İsteğe bağlı tam gateway URL (boşsa SECURE_TYPE + test/canlıya göre seçilir).
# 3DPay için …/Default.aspx, 3DHost için …/3DHost.aspx olmalı; QNB_FORCE_3DPAY=true iken 3DHost URL’si sayfayı hata verir.
# QNB_GATEWAY_URL="https://vpostest.qnb.com.tr/Gateway/Default.aspx"
# true: banka sayfası YOK, doğrudan başarı sayfası (yalnızca geliştirme). Canlıda banka ekranı için false.
QNB_USE_MOCK="true"
# Banka UI incelemesi: QNB env eksikken checkout/qnb-baslat demo kart ekranı (gerçek ödeme / QNB çağrısı yok). Canlıda kapatın.
# BANK_REVIEW_MODE="true"
# Banka dönüş hash’i dökümanla uyuşmuyorsa geçici: true (üretimde kapatın)
# QNB_RELAX_RETURN_HASH="false"

# --- PayTR (aktif kart ödeme sağlayıcısı) ---
# Değerleri PayTR Mağaza Paneli > Bilgiler bölümünden alın. Sohbete YAZMAYIN; yalnızca .env.local + Vercel.
# PayTR Panel > Ayarlar > Bildirim URL = https://<site>/api/payments/paytr-callback olarak ayarlanmalı.
PAYTR_MERCHANT_ID=""
PAYTR_MERCHANT_KEY=""
PAYTR_MERCHANT_SALT=""
# Test: 1 (PayTR test kartlarıyla) | Canlı: 0
PAYTR_TEST_MODE="1"

